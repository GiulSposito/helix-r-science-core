# Data Files
# ============================================================================

# Large data files (add specific patterns as needed)
*.csv.gz
*.parquet
*.feather
*.rds
*.RData
*.rda

# Database files
*.db
*.sqlite
*.sqlite3

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# ============================================================================
# Credentials and Secrets
# ============================================================================

# Environment files
.env
.env.*
!.env.example
!.env.template

# API keys and credentials
**/credentials.json
**/secrets.yaml
**/secrets.yml
**/.secrets/
**/*.key
**/*.pem
**/*.p12
**/*.pfx

# ============================================================================
# Documentation Build Artifacts
# ============================================================================

# Quarto
.quarto/
_site/
_book/
/.luarc.json

# Sphinx
_build/
_static/
_templates/

# MkDocs
site/

# ============================================================================
# Logs and Temporary Files
# ============================================================================

# Log files
*.log
logs/
*.out
*.err

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup
*~.nib

# ============================================================================
# Testing and CI/CD
# ============================================================================

# Test outputs
test-results/
test-output/
coverage/
.nyc_output/

# CI/CD artifacts
.github/workflows/artifacts/

# ============================================================================
# Docker
# ============================================================================

# Docker files (if using for deployment)
docker-compose.override.yml
.docker/

# ============================================================================
# Project-Specific Exclusions
# ============================================================================

# Validation reports (optional - uncomment if you don't want to track them)
# **/VALIDATION*.md
# **/STATUS.md
# **/TODO.md

# Generated model artifacts
models/trained/
models/checkpoints/
*.h5
*.hdf5
*.ckpt
*.pt
*.pth

# Large workflow outputs
workflows/outputs/
workflows/artifacts/

# ============================================================================
# Keep These Files (Negation Patterns)
# ============================================================================

# Keep example/template files
!.env.example
!.env.template
!**/example.yaml
!**/template.yaml

# Keep important config templates
!_bmad/config.yaml
!_bmad/rds/config.yaml

# Keep README files
!**/README.md
!**/README.txt

# Keep .gitkeep files to preserve empty directories
!**/.gitkeep
